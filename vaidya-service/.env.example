# Vaidya agent service config. Copy to .env (gitignored).

PORT=8090

# Shared Postgres — this service owns the vaidya_* tables (read+write). Reads of
# health data go through the MCP server, not this DSN.
DATABASE_URL=postgres://fitvibe:fitvibe@localhost:5432/fitvibe?sslmode=disable

# Runtime model. Anthropic OAuth is used (no API key) — Pi reads ~/.pi/agent/auth.json.
# Switch to an OpenCode Zen model id here later.
VAIDYA_MODEL_PROVIDER=anthropic
VAIDYA_MODEL_ID=claude-opus-4-8

# How the embedded Pi reaches vaidya-mcp is declared in .mcp.json (a streamable-
# HTTP url). Start vaidya-mcp separately (it's its own service):
#   cd ../vaidya-mcp && .venv/Scripts/python -m vaidya_mcp.server
# It serves http://127.0.0.1:8765/mcp by default.

# Firebase (Part E — for the HTTP insight endpoints; same project as Go).
# FIREBASE_PROJECT_ID=fitvibe-1781246667365
# FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json
