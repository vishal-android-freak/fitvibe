# FitVibe full-stack docker-compose config. Copy to .env in the repo root:
#   cp .env.docker.example .env
# docker compose reads .env automatically. Never commit your real .env.

# ── Database (runs in compose) ───────────────────────────────────────────────
POSTGRES_USER=fitvibe
POSTGRES_PASSWORD=fitvibe
POSTGRES_DB=fitvibe
# Password for the least-privilege read-only role the Vaidya MCP server uses.
VAIDYA_RO_PASSWORD=change-me-readonly

# ── Secret files: the ./config folder (mounted read-only at /config) ─────────
# Put your credential files in ./config (see config/README.md). The folder is
# mounted into the backend + vaidya-service at /config. Override the host path
# only if your config dir lives elsewhere:
# CONFIG_DIR=./config

# ── Google OAuth + Health API (required for the backend) ─────────────────────
# Copy these from the OAuth client you downloaded (config/google-oauth.json).
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=com.fitvibe.app:/oauth2callback
WEBHOOK_SECRET=Bearer super-secret

# ── Firebase (app auth; same project as Go) ──────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path INSIDE the container — resolves to ./config/firebase-service-account.json
# on the host. Place that file in ./config (keep it out of git).
FIREBASE_CREDENTIALS_FILE=/config/firebase-service-account.json

# ── Internal token provider (backend → vaidya-mcp, over the compose network) ──
# Shared bearer secret; the loopback/compose-network binding is the real boundary.
INTERNAL_TOKEN_SECRET=change-me-internal

# ── Vaidya model ─────────────────────────────────────────────────────────────
VAIDYA_MODEL_PROVIDER=anthropic
VAIDYA_MODEL_ID=claude-opus-4-8
# Pi uses Anthropic OAuth from the host's ~/.pi/agent (mounted into the
# container). Run `pi` once on the host so auth.json exists. Override the host
# path if your Pi agent dir isn't at ~/.pi/agent:
# PI_AGENT_HOST_PATH=/home/you/.pi/agent

# ── Caddy / networking ───────────────────────────────────────────────────────
# Leave DOMAIN empty for localhost (HTTP on :80). Set a real hostname for
# automatic HTTPS (requires public DNS + ports 80/443 reachable):
# DOMAIN=health.example.com
HTTP_PORT=80
HTTPS_PORT=443
