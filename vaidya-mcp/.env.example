# Vaidya MCP server config. Copy to .env (gitignored).

# Postgres connection for the READ-ONLY role (see sql/role_provisioning.sql).
# This role can SELECT the health tables and has NO write access anywhere.
DATABASE_URL_READONLY=postgres://vaidya_ro:CHANGE_ME@localhost:5432/fitvibe?sslmode=disable

# How to reach the Go internal token provider (which mints fresh Google access
# tokens). Prefer the Unix socket in prod; use the http URL on Windows dev.
# Exactly one of these is used (socket wins when set).
# GO_TOKEN_SOCKET=/run/fitvibe/token.sock
GO_TOKEN_URL=http://127.0.0.1:8091
INTERNAL_TOKEN_SECRET=change-me-internal

# Google Health API base for writes.
GOOGLE_HA_BASE=https://health.googleapis.com/v4
