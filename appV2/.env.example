# Copy to .env and fill in. EXPO_PUBLIC_* vars are inlined into the app bundle
# at build time, so do NOT put secrets here (the Google client SECRET lives only
# on the backend; the client ID below is public and safe to ship).

# FitVibe Go backend base URL (no trailing slash).
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# Google OAuth client ID — must be an iOS/Android-type client whose authorized
# redirect URI includes  fitvibe://oauthredirect
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
