PORT=8080
HOST=0.0.0.0
WEBHOOK_PATH=/webhooks/google-health
WEBHOOK_SECRET=Bearer super-secret

GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=com.fitvibe.app:/oauth2callback
GOOGLE_PROJECT_NUMBER=your-project-number

# PostgreSQL connection (pgx DSN). For local dev, `docker compose up -d` starts
# a matching instance. Use sslmode=require (or verify-full) for the office server.
DATABASE_URL=postgres://fitvibe:fitvibe@localhost:5432/fitvibe?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=2

WEBHOOK_SIGNATURE_CACHE_TTL=24h

# Firebase Auth — mints a custom token after Google OAuth (so the app signs in
# with no extra step) and verifies the app's ID tokens on /me/* (uid = google
# user id). FIREBASE_CREDENTIALS_FILE points at the Admin service-account JSON
# (keep it out of git); leave empty to use GOOGLE_APPLICATION_CREDENTIALS / ADC.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json

# Internal token provider for the local Vaidya MCP server (serves fresh Google
# access tokens off the public router; Go stays the sole token authority).
# Prefer the Unix socket (prod/Pi); on Windows dev use the loopback addr instead.
# Leave BOTH empty to disable. INTERNAL_TOKEN_SECRET is a defense-in-depth bearer
# check — the socket/loopback binding is the real boundary.
# INTERNAL_TOKEN_SOCKET=/run/fitvibe/token.sock
INTERNAL_TOKEN_ADDR=127.0.0.1:8091
INTERNAL_TOKEN_SECRET=change-me-internal

DEFAULT_BACKFILL_DAYS=30
CRON_INTRADAY_ROLLUP="0 * * * *"
CRON_DAILY_ROLLUP="10 0 * * *"
CRON_LIST_SYNC="0 */6 * * *"
CRON_PROFILE_SETTINGS_SYNC="0 2 * * *"
CRON_RECONCILE_SYNC="0 3 * * *"
# Re-lists webhook-supported data types to recover notifications missed during
# downtime. Runs every 3 hours; each run re-fetches the last CATCHUP_LOOKBACK_HOURS.
CRON_CATCHUP_SYNC="0 */3 * * *"
CATCHUP_LOOKBACK_HOURS=48
