# Whitelist: ignore everything in the repo root except the services, the
# documentation, and the top-level project files listed below.
/*
!/backend
!/backend/**
!/appV2
!/appV2/**
!/vaidya-mcp
!/vaidya-mcp/**
!/vaidya-service
!/vaidya-service/**
!/.pi
!/.pi/**
!/design_handoff_fitvibe_app
!/design_handoff_fitvibe_app/**
!/docs
!/docs/**
!/feature-image
!/feature-image/**
!/deploy
!/deploy/**
!/config
!/config/**
!/docker-compose.yml
!/.env.docker.example
!/README.md
!/CLAUDE.md
!/LICENSE
!/CONTRIBUTING.md
!/.gitignore
!/.gitattributes

# Re-ignore heavy/generated dirs inside the re-included folders.
/appV2/node_modules
/vaidya-mcp/.venv
/vaidya-mcp/__pycache__
/vaidya-mcp/**/__pycache__
/vaidya-mcp/.env
/vaidya-mcp/*.log
/vaidya-service/node_modules
/vaidya-service/dist
/vaidya-service/.env
/vaidya-service/.pi-auth
/vaidya-service/pi-sessions
/appV2/.expo
/appV2/dist
/appV2/web-build
/appV2/ios
/appV2/android
**/node_modules/
/appV2/.claude
/feature-image/node_modules
/feature-image/out
